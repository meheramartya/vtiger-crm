<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Cross Browser Testing Suite" parallel="tests" thread-count="3">
  <!-- 
    parallel="tests" - Run multiple <test> tags at the SAME TIME
    thread-count="3" - Use 3 browser windows simultaneously
  -->
  
  <!-- Thread 1: Chrome -->
  <test thread-count="3" name="Chrome Tests">
    <parameter name="browser" value="chrome"/>
    <classes>
      <class name="contactModule.ContactModule"/>
      <class name="organizationModule.OrganizationModule"/>
    </classes>
  </test>
  
  <!-- Thread 2: Edge (Runs at SAME TIME as Chrome) -->
  <test thread-count="3" name="Edge Tests">
    <parameter name="browser" value="edge"/>
    <classes>
      <class name="contactModule.ContactModule"/>
      <class name="organizationModule.OrganizationModule"/>
    </classes>
  </test>

  
</suite>